<Window x:Class="RegistroPromedios.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:RegistroPromedios"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#1E40AF" Height="35" Margin="0,0,0,10">
            <TextBlock Text="CONTROL DE EVALUACIONES" Foreground="White" HorizontalAlignment="Center" 
                       VerticalAlignment="Center" FontSize="15" FontWeight="Bold"/>
        </Border>

        <GroupBox Grid.Row="1" Header="DATOS GENERALES" FontSize="11" Margin="0,0,0,10" Padding="5">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="1.5*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="1*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="10"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="Apellidos:" VerticalAlignment="Center" Margin="5,0,5,0"/>
                <TextBox x:Name="txtApellidos" Grid.Row="0" Grid.Column="1" Height="23"/>

                <TextBlock Grid.Row="0" Grid.Column="2" Text="Nombres:" VerticalAlignment="Center" Margin="15,0,5,0"/>
                <TextBox x:Name="txtNombres" Grid.Row="0" Grid.Column="3" Height="23"/>

                <TextBlock Grid.Row="2" Grid.Column="0" Text="Código:" VerticalAlignment="Center" Margin="5,0,5,0"/>
                <TextBox x:Name="txtCodigo" Grid.Row="2" Grid.Column="1" Height="23"/>

                <TextBlock Grid.Row="2" Grid.Column="2" Text="Nivel de estudiante:" VerticalAlignment="Center" Margin="15,0,5,0"/>
                <ComboBox x:Name="cmbNivel" Grid.Row="2" Grid.Column="3" Height="23"/>
            </Grid>
        </GroupBox>

        <GroupBox Grid.Row="2" Header="EVALUACIONES" FontSize="11" Padding="5" Margin="0,0,0,5">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="1*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" BorderBrush="DimGray" BorderThickness="1" CornerRadius="3" Padding="8">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1*"/>
                            <ColumnDefinition Width="15"/>
                            <ColumnDefinition Width="1.2*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Notas" FontWeight="SemiBold" Margin="2,0,0,3"/>

                        <StackPanel Grid.Row="1" Grid.Column="0" Orientation="Horizontal">
                            <Label Content="Eval. 1" Padding="0,3,0,0" Width="42" FontSize="10"/>
                            <TextBox x:Name="txtEval1" Width="35" Height="23" HorizontalContentAlignment="Center"/>

                            <Label Content="Eval. 2" Padding="8,3,0,0" Width="50" FontSize="10"/>
                            <TextBox x:Name="txtEval2" Width="35" Height="23" HorizontalContentAlignment="Center"/>

                            <Label Content="Eval. 3" Padding="8,3,0,0" Width="50" FontSize="10"/>
                            <TextBox x:Name="txtEval3" Width="35" Height="23" HorizontalContentAlignment="Center"/>
                        </StackPanel>

                        <StackPanel Grid.Row="1" Grid.Column="2">
                            <DockPanel Margin="0,0,0,3">
                                <Label Content="Promedio:" DockPanel.Dock="Left" Padding="0,3,3,0" Width="60" FontSize="10"/>
                                <TextBox x:Name="txtPromedioOutput" IsReadOnly="True" Height="23" Background="#FFF4F4F4" HorizontalContentAlignment="Center"/>
                            </DockPanel>
                            <DockPanel>
                                <Label Content="Condición:" DockPanel.Dock="Left" Padding="0,3,3,0" Width="60" FontSize="10"/>
                                <TextBox x:Name="txtCondicionOutput" IsReadOnly="True" Height="23" Background="#FFF4F4F4" HorizontalContentAlignment="Center"/>
                            </DockPanel>
                        </StackPanel>
                    </Grid>
                </Border>

                <StackPanel Grid.Column="1" VerticalAlignment="Bottom" HorizontalAlignment="Right" Margin="10,0,0,0">
                    <Button x:Name="btnAgregarNotas" Content="AGREGAR NOTAS" Width="120" Height="28" Margin="0,0,0,8" 
                            Background="#D1FAE5" BorderBrush="#10B981" FontWeight="Bold" Click="btnAgregarNotas_Click"/>
                </StackPanel>
            </Grid>
        </GroupBox>

        <TextBlock Grid.Row="3" Text="⬇️" FontSize="16" HorizontalAlignment="Center" Margin="0,0,0,5"/>

        <ListView x:Name="lvResultados" Grid.Row="4" Margin="0,0,0,15" Background="#F9FAFB">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="ESTUDIANTE" DisplayMemberBinding="{Binding NombreCompleto}" Width="210"/>
                    <GridViewColumn Header="CÓDIGO" DisplayMemberBinding="{Binding Codigo}" Width="65"/>
                    <GridViewColumn Header="NIVEL" DisplayMemberBinding="{Binding Nivel}" Width="70"/>
                    <GridViewColumn Header="EVAL. 1" DisplayMemberBinding="{Binding Eval1}" Width="55"/>
                    <GridViewColumn Header="EVAL. 2" DisplayMemberBinding="{Binding Eval2}" Width="55"/>
                    <GridViewColumn Header="EVAL. 3" DisplayMemberBinding="{Binding Eval3}" Width="55"/>
                    <GridViewColumn Header="PROMEDIO" DisplayMemberBinding="{Binding PromedioFormatted}" Width="65"/>
                    <GridViewColumn Header="CONDICIÓN" DisplayMemberBinding="{Binding Condicion}" Width="80"/>
                </GridView>
            </ListView.View>
        </ListView>

        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="btnMediaPromedios" Content="MEDIA DE PROMEDIOS" Width="150" Height="28" Margin="0,0,10,0"
                    Background="#DBEAFE" BorderBrush="#3B82F6" FontWeight="Bold" Click="btnMediaPromedios_Click"/>
            <TextBox x:Name="txtMediaPromedios" IsReadOnly="True" Width="80" Height="28" Background="#FFF4F4F4" 
                     HorizontalContentAlignment="Center" VerticalContentAlignment="Center" FontWeight="Bold"/>
        </StackPanel>
    </Grid>
</Window>
