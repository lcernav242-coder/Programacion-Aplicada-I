<Window x:Class="OrdenarCadenas.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:OrdenarCadenas"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,15">
            <TextBox x:Name="txtCadenaOriginal" 
                     Height="80" 
                     TextWrapping="Wrap" 
                     AcceptsReturn="True" 
                     VerticalScrollBarVisibility="Auto"
                     Padding="5"
                     Text="Liliana Angelina Leticia Amanda Patricia Roxana Luana Laura Kiara Kimberly Synthia Cintia Cecilia Ana Lina Thalia Teresa Pierina" 
                     FontWeight="Bold" FontSize="16"/>

            <Button x:Name="btnListar" 
                    Click="btnListar_Click"
                    Content="&lt;&lt;Listar&gt;&gt;" 
                    Width="100" 
                    Height="30" 
                    HorizontalAlignment="Left" 
                    Margin="0,10,0,0" FontWeight="Bold"/>
        </StackPanel>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="1.5*"/>
                <ColumnDefinition Width="2*"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="Letra" HorizontalAlignment="Center" FontWeight="Bold" Margin="0,0,0,5"/>
                <TextBox x:Name="txtLetraFiltro" Width="90" Height="25" HorizontalContentAlignment="Center" MaxLength="1" CharacterCasing="Upper"/>

                <Button x:Name="btnPasar" 
                        Click="btnPasar_Click"
                        Content="&lt;&lt;Pasar&gt;&gt;" 
                        Width="100" 
                        Height="30" 
                        Margin="0,20,0,0"/>
            </StackPanel>

            <ListBox x:Name="lstTodos" Grid.ColumnSpan="2" Margin="10,10,198,-10" FontWeight="Bold" FontSize="14"/>
            <ListBox x:Name="lstFiltrados" Grid.Column="2" FontWeight="Bold" FontSize="14"/>
        </Grid>

        <Grid Grid.Row="2" Margin="0,10,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="1.5*"/>
                <ColumnDefinition Width="2*"/>
            </Grid.ColumnDefinitions>

            <TextBox x:Name="txtContadorTotal" Grid.Column="1" Width="58" Height="22" HorizontalAlignment="Left" IsReadOnly="True" HorizontalContentAlignment="Center" Margin="24,0,0,0"/>
            <TextBox x:Name="txtContadorFiltrados" Grid.Column="1" Width="59" Height="22" HorizontalAlignment="Left" Margin="122,0,0,0" IsReadOnly="True" HorizontalContentAlignment="Center"/>
        </Grid>
    </Grid>
</Window>
