<Window x:Class="EncriptarClave.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:EncriptarClave"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        <StackPanel Margin="20" VerticalAlignment="Center">

            <TextBlock Text="Ingrese la clave original:" FontWeight="Bold" Margin="0,0,0,5"/>
            <TextBox x:Name="txtClaveOriginal" Height="30" FontSize="14" Padding="3" Margin="0,0,0,15"/>

            <Button x:Name="btnEncriptar" 
                Content="Encriptar Clave" 
                Width="120" 
                Height="35" 
                FontWeight="Bold"
                Click="btnEncriptar_Click"/>

            <TextBlock Text="Clave Encriptada:" FontWeight="Bold" Margin="0,20,0,5"/>
            <TextBox x:Name="txtClaveEncriptada" 
                 Height="30" 
                 FontSize="14" 
                 Padding="3" 
                 IsReadOnly="True" 
                 Background="#FFEAEAEA" 
                 Foreground="Red" 
                 FontWeight="Bold"/>

        </StackPanel>
    </Grid>
</Window>
