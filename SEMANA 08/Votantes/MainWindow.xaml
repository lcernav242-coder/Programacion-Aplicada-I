<Window x:Class="Votantes.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Votantes"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800" Loaded="Window_Loaded">
    <Grid Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="500"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Column="0" Grid.Row="0" Margin="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="30"/>
                <RowDefinition Height="40"/>
                <RowDefinition Height="40"/>
                <RowDefinition Height="40"/>
                <RowDefinition Height="40"/>
                <RowDefinition Height="40"/>
            </Grid.RowDefinitions>

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="80"/>
                <ColumnDefinition Width="65"/>
                <ColumnDefinition Width="65"/>
                <ColumnDefinition Width="65"/>
                <ColumnDefinition Width="65"/>
                <ColumnDefinition Width="70"/>
            </Grid.ColumnDefinitions>


            <TextBlock Text="A" Grid.Row="0" Grid.Column="1" HorizontalAlignment="Center" FontWeight="Bold"/>
            <TextBlock Text="B" Grid.Row="0" Grid.Column="2" HorizontalAlignment="Center" FontWeight="Bold"/>
            <TextBlock Text="C" Grid.Row="0" Grid.Column="3" HorizontalAlignment="Center" FontWeight="Bold"/>
            <TextBlock Text="D" Grid.Row="0" Grid.Column="4" HorizontalAlignment="Center" FontWeight="Bold"/>


            <TextBlock Text="Buhito" Grid.Row="1" Grid.Column="0" VerticalAlignment="Center"/>
            <TextBox x:Name="txt00" Grid.Row="1" Grid.Column="1" Width="50" Height="25" HorizontalContentAlignment="Center"/>
            <TextBox x:Name="txt01" Grid.Row="1" Grid.Column="2" Width="50" Height="25" HorizontalContentAlignment="Center"/>
            <TextBox x:Name="txt02" Grid.Row="1" Grid.Column="3" Width="50" Height="25" HorizontalContentAlignment="Center"/>
            <TextBox x:Name="txt03" Grid.Row="1" Grid.Column="4" Width="50" Height="25" HorizontalContentAlignment="Center"/>
            <TextBlock x:Name="tbTotalP0" Text="0" Grid.Row="1" Grid.Column="5" VerticalAlignment="Center" HorizontalAlignment="Center"/>


            <TextBlock Text="Aguila" Grid.Row="2" Grid.Column="0" VerticalAlignment="Center"/>
            <TextBox x:Name="txt10" Grid.Row="2" Grid.Column="1" Width="50" Height="25" HorizontalContentAlignment="Center"/>
            <TextBox x:Name="txt11" Grid.Row="2" Grid.Column="2" Width="50" Height="25" HorizontalContentAlignment="Center"/>
            <TextBox x:Name="txt12" Grid.Row="2" Grid.Column="3" Width="50" Height="25" HorizontalContentAlignment="Center"/>
            <TextBox x:Name="txt13" Grid.Row="2" Grid.Column="4" Width="50" Height="25" HorizontalContentAlignment="Center"/>
            <TextBlock x:Name="tbTotalP1" Text="0" Grid.Row="2" Grid.Column="5" VerticalAlignment="Center" HorizontalAlignment="Center"/>


            <TextBlock Text="Torito" Grid.Row="3" Grid.Column="0" VerticalAlignment="Center"/>
            <TextBox x:Name="txt20" Grid.Row="3" Grid.Column="1" Width="50" Height="25" HorizontalContentAlignment="Center"/>
            <TextBox x:Name="txt21" Grid.Row="3" Grid.Column="2" Width="50" Height="25" HorizontalContentAlignment="Center"/>
            <TextBox x:Name="txt22" Grid.Row="3" Grid.Column="3" Width="50" Height="25" HorizontalContentAlignment="Center"/>
            <TextBox x:Name="txt23" Grid.Row="3" Grid.Column="4" Width="50" Height="25" HorizontalContentAlignment="Center"/>
            <TextBlock x:Name="tbTotalP2" Text="0" Grid.Row="3" Grid.Column="5" VerticalAlignment="Center" HorizontalAlignment="Center"/>


            <TextBlock Text="Lorito" Grid.Row="4" Grid.Column="0" VerticalAlignment="Center"/>
            <TextBox x:Name="txt30" Grid.Row="4" Grid.Column="1" Width="50" Height="25" HorizontalContentAlignment="Center"/>
            <TextBox x:Name="txt31" Grid.Row="4" Grid.Column="2" Width="50" Height="25" HorizontalContentAlignment="Center"/>
            <TextBox x:Name="txt32" Grid.Row="4" Grid.Column="3" Width="50" Height="25" HorizontalContentAlignment="Center"/>
            <TextBox x:Name="txt33" Grid.Row="4" Grid.Column="4" Width="50" Height="25" HorizontalContentAlignment="Center"/>
            <TextBlock x:Name="tbTotalP3" Text="0" Grid.Row="4" Grid.Column="5" VerticalAlignment="Center" HorizontalAlignment="Center"/>


            <TextBlock x:Name="tbTotalZ0" Text="0" Grid.Row="5" Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            <TextBlock x:Name="tbTotalZ1" Text="0" Grid.Row="5" Grid.Column="2" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            <TextBlock x:Name="tbTotalZ2" Text="0" Grid.Row="5" Grid.Column="3" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            <TextBlock x:Name="tbTotalZ3" Text="0" Grid.Row="5" Grid.Column="4" HorizontalAlignment="Center" VerticalAlignment="Center"/>



        </Grid>

        <StackPanel Grid.Column="1" Grid.Row="0" VerticalAlignment="Center" HorizontalAlignment="Center" Width="180">
            <Button x:Name="btnCalcular" Content="Resultados" Height="35" FontSize="14" Background="#FF67BDDA"/>

            <TextBlock Text="Total Votantes" Background="#A5D6A7" Padding="5" FontWeight="Bold" TextAlignment="Center" Margin="0,20,0,5"/>
            <TextBlock x:Name="tbTotalVotantes" Text="0" Background="#C8E6C9" Padding="8" TextAlignment="Center" FontSize="16" FontWeight="Bold"/>
        </StackPanel>


        <UniformGrid Grid.Row="1" Grid.ColumnSpan="2" Columns="2" Margin="10,20,10,10">

            <StackPanel HorizontalAlignment="Center" Width="200">
                <TextBlock Text="Candidato Ganador" Background="#A5D6A7" Padding="5" FontWeight="Bold" TextAlignment="Center" Margin="0,0,0,5"/>
                <TextBlock x:Name="lblCandidatoGanador" Text="-" Background="#C8E6C9" Padding="8" TextAlignment="Center" FontSize="16" FontWeight="Bold"/>
            </StackPanel>

            <StackPanel HorizontalAlignment="Center" Width="200">
                <TextBlock Text="Zona con más votantes" Background="#A5D6A7" Padding="5" FontWeight="Bold" TextAlignment="Center" Margin="0,0,0,5"/>
                <TextBlock x:Name="lblZonaMax" Text="-" Background="#C8E6C9" Padding="8" TextAlignment="Center" FontSize="16" FontWeight="Bold"/>
            </StackPanel>
        </UniformGrid>




    </Grid>
</Window>