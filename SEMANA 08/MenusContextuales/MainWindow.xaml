<Window x:Class="MenusContextuales.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:local="clr-namespace:MenusContextuales"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid Margin="30,25,30,25">
        <Button Content="hacer click derecho!" HorizontalAlignment="Center" VerticalAlignment="Center" Padding="10,5,10,5" BorderThickness="1,1,1,1">
            <Button.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="Menu Item 1"/>
                    <MenuItem Header="Menu Item 2"/>
                    <Separator/>
                    <MenuItem Header="Salir">
                        <MenuItem.Icon>
                            <materialDesign:PackIcon 
                                Kind="ExitToApp"
                                Width="24"
                                Foreground="Blue"/>
                        </MenuItem.Icon>
                    </MenuItem>
                </ContextMenu>
            </Button.ContextMenu>
        </Button>
        <TextBox HorizontalAlignment="Left" Margin="176,223,0,0" TextWrapping="Wrap" Text="Click derecho para mostrar el Menu Contextual" VerticalAlignment="Top" Width="391">
            <TextBox.ContextMenu>
                <ContextMenu>
                    <MenuItem Command="Cut">
                        <MenuItem.Icon>
                            <Image Source="/Iconos/icons8-cut-50.png" />
                        </MenuItem.Icon>
                    </MenuItem>
                    <MenuItem Command="Copy">
                        <MenuItem.Icon>
                            <Image Source="/Iconos/icons8-copy-30.png" />
                        </MenuItem.Icon>
                    </MenuItem>
                    <MenuItem Command="Paste">
                        <MenuItem.Icon>
                            <Image Source="/Iconos/icons8-paste-50.png" />
                        </MenuItem.Icon>
                    </MenuItem>
                </ContextMenu>
            </TextBox.ContextMenu>
        </TextBox>

    </Grid>
</Window>