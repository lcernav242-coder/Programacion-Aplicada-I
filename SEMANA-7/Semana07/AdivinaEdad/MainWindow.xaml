<Window x:Class="AdivinaEdad.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:AdivinaEdad"
        mc:Ignorable="d"
        Title="AdivinaEdad" Height="450" Width="600">

    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">

        <TextBlock Text="Indícale al computador un intervalo de edades" 
                   HorizontalAlignment="Center" 
                   FontWeight="Bold" 
                   FontSize="14" 
                   Margin="0,0,0,15"/>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,20">
            <TextBox x:Name="txtMinimo" Width="60" Height="30" TextAlignment="Center" FontSize="14" Margin="0,0,50,0"/>
            <TextBox x:Name="txtMaximo" Width="60" Height="30" TextAlignment="Center" FontSize="14"/>
        </StackPanel>

        <Button x:Name="btnPrimerIntento" 
                Content="Primer intento" 
                Width="120" 
                Height="30" 
                Margin="0,0,0,30" 
                Click="btnPrimerIntento_Click"/>

        <TextBlock Text="La computadora piensa que tu edad es" 
                   HorizontalAlignment="Center" 
                   FontWeight="Bold" 
                   FontSize="14" 
                   Margin="0,0,0,15"/>

        <TextBox x:Name="txtEdadAdivinada" 
                 Width="60" 
                 Height="30" 
                 TextAlignment="Center" 
                 FontSize="14" 
                 IsReadOnly="True" 
                 Margin="0,0,0,30"/>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
            <Button x:Name="btnCorrecto" 
                    Content="Correcto" 
                    Width="90" 
                    Height="30" 
                    Margin="0,0,50,0" 
                    Click="btnCorrecto_Click"
                    IsEnabled="False"/>

            <Button x:Name="btnIncorrecto" 
                    Content="Incorrecto" 
                    Width="90" 
                    Height="30" 
                    Click="btnIncorrecto_Click"
                    IsEnabled="False"/>
        </StackPanel>

    </StackPanel>
</Window>