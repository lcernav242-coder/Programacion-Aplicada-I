<Window x:Class="TragamonedasV2.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Tragamonedas_v2" Height="450" Width="700"
        Background="#E8F4E8">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="1.5*"/>
            <!-- Espacio para el Reloj -->
            <RowDefinition Height="1*"/>
            <!-- Espacio para el Botón -->
            <RowDefinition Height="3*"/>
            <!-- Espacio para las Imágenes y Puntaje -->
            <RowDefinition Height="1*"/>
            <!-- Espacio para el Mensaje Final -->
        </Grid.RowDefinitions>

        <!-- 1. Reloj (Usamos Viewbox para que el texto escale automáticamente con la ventana) -->
        <Viewbox Grid.Row="0" Margin="10">
            <TextBlock x:Name="txtReloj" 
                       Text="19:18:55" 
                       Foreground="#666666" 
                       FontWeight="Light"/>
        </Viewbox>

        <!-- 2. Botón Iniciar -->
        <Button x:Name="btnIniciar" 
        Click="btnIniciar_Click"
        Grid.Row="1" 
        Content="Iniciar Juego" 
        HorizontalAlignment="Center" 
        VerticalAlignment="Center" 
        Padding="20,5" 
        FontSize="16" 
        FontWeight="Bold"
        Background="#E0E0E0" 
        Foreground="#444444"/>

        <!-- 3. Área de Juego (Imágenes) y Puntaje -->
        <Grid Grid.Row="2" Margin="0,20,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="4*"/>
                <!-- 80% del ancho para las imágenes -->
                <ColumnDefinition Width="1*"/>
                <!-- 20% del ancho para el puntaje -->
            </Grid.ColumnDefinitions>

            <!-- UniformGrid asegura que los 3 slots sean idénticos y responsivos -->
            <UniformGrid Grid.Column="0" Columns="3" Margin="0,0,20,0">
                <!-- Imagen 1 -->
                <Border Background="#6B5B95" Margin="10" CornerRadius="2">
                    <Image x:Name="imgSlot1" Stretch="Uniform" Margin="10"/>
                </Border>

                <!-- Imagen 2 -->
                <Border Background="#6B5B95" Margin="10" CornerRadius="2">
                    <Image x:Name="imgSlot2" Stretch="Uniform" Margin="10"/>
                </Border>

                <!-- Imagen 3 -->
                <Border Background="#6B5B95" Margin="10" CornerRadius="2">
                    <Image x:Name="imgSlot3" Stretch="Uniform" Margin="10"/>
                </Border>
            </UniformGrid>

            <!-- Panel lateral derecho para el Puntaje -->
            <StackPanel Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="Puntaje:" 
                           FontWeight="Bold" 
                           FontSize="14" 
                           HorizontalAlignment="Center" 
                           Margin="0,0,0,5" 
                           Foreground="#444444"/>

                <Border Background="#EBD95F" Padding="15,10" CornerRadius="2">
                    <TextBlock x:Name="txtPuntaje" 
                               Text="10" 
                               FontSize="28" 
                               FontWeight="Bold" 
                               Foreground="#333333" 
                               HorizontalAlignment="Center"/>
                </Border>
            </StackPanel>
        </Grid>

        <!-- 4. Mensaje inferior -->
        <!-- Se envuelve en un Viewbox sutil para que crezca o se encoja sin desbordar la pantalla -->
        <Viewbox Grid.Row="3" Margin="10" StretchDirection="DownOnly">
            <TextBlock x:Name="txtResultado" 
                       Text="PERDISTE, puntaje obtenido: 10" 
                       HorizontalAlignment="Center" 
                       VerticalAlignment="Center" 
                       FontSize="20" 
                       FontWeight="Bold" 
                       Foreground="#5A6D7C"/>
        </Viewbox>
    </Grid>
</Window>