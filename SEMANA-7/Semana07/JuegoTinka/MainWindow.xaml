<Window x:Class="JuegoTinka.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="La Tinka" Height="500" Width="850" Background="White">

    <Grid Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1.2*"/>
            <ColumnDefinition Width="1*"/>
        </Grid.ColumnDefinitions>

    
        <StackPanel Grid.Column="0" Margin="0,0,20,0">

            <TextBlock Text="1. REGISTRO DEL JUGADOR" Foreground="#1C3D82" FontWeight="Bold" FontSize="14" Margin="0,0,0,15"/>

            <Grid Margin="0,0,0,25">
                <Grid.RowDefinitions>
                    <RowDefinition Height="30"/>
                    <RowDefinition Height="30"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="80"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="Nombre:" VerticalAlignment="Center" Foreground="#333"/>
                <TextBox x:Name="txtNombre" Grid.Column="1" Margin="0,2" VerticalContentAlignment="Center" CharacterCasing="Upper"/>

                <TextBlock Grid.Row="1" Text="Dirección:" VerticalAlignment="Center" Foreground="#333"/>
                <TextBox x:Name="txtDireccion" Grid.Row="1" Grid.Column="1" Margin="0,2" VerticalContentAlignment="Center" CharacterCasing="Upper"/>
            </Grid>

            <TextBlock Text="2. INGRESA TUS JUGADAS (1 al 45)" Foreground="#1C3D82" FontWeight="Bold" FontSize="14" Margin="0,0,0,10"/>

            <Border Background="#4578D4" Padding="15" CornerRadius="5" Margin="0,0,0,20">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="35"/>
                        <RowDefinition Height="35"/>
                        <RowDefinition Height="35"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="70"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Jugada 1:" Foreground="White" VerticalAlignment="Center" FontWeight="Bold"/>
                    <TextBox x:Name="txtJ1_1" Grid.Row="0" Grid.Column="1" Margin="3" TextAlignment="Center" VerticalContentAlignment="Center" FontSize="16" FontWeight="Bold"/>
                    <TextBox x:Name="txtJ1_2" Grid.Row="0" Grid.Column="2" Margin="3" TextAlignment="Center" VerticalContentAlignment="Center" FontSize="16" FontWeight="Bold"/>
                    <TextBox x:Name="txtJ1_3" Grid.Row="0" Grid.Column="3" Margin="3" TextAlignment="Center" VerticalContentAlignment="Center" FontSize="16" FontWeight="Bold"/>
                    <TextBox x:Name="txtJ1_4" Grid.Row="0" Grid.Column="4" Margin="3" TextAlignment="Center" VerticalContentAlignment="Center" FontSize="16" FontWeight="Bold"/>
                    <TextBox x:Name="txtJ1_5" Grid.Row="0" Grid.Column="5" Margin="3" TextAlignment="Center" VerticalContentAlignment="Center" FontSize="16" FontWeight="Bold"/>
                    <TextBox x:Name="txtJ1_6" Grid.Row="0" Grid.Column="6" Margin="3" TextAlignment="Center" VerticalContentAlignment="Center" FontSize="16" FontWeight="Bold"/>

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Jugada 2:" Foreground="White" VerticalAlignment="Center" FontWeight="Bold"/>
                    <TextBox x:Name="txtJ2_1" Grid.Row="1" Grid.Column="1" Margin="3" TextAlignment="Center" VerticalContentAlignment="Center" FontSize="16" FontWeight="Bold"/>
                    <TextBox x:Name="txtJ2_2" Grid.Row="1" Grid.Column="2" Margin="3" TextAlignment="Center" VerticalContentAlignment="Center" FontSize="16" FontWeight="Bold"/>
                    <TextBox x:Name="txtJ2_3" Grid.Row="1" Grid.Column="3" Margin="3" TextAlignment="Center" VerticalContentAlignment="Center" FontSize="16" FontWeight="Bold"/>
                    <TextBox x:Name="txtJ2_4" Grid.Row="1" Grid.Column="4" Margin="3" TextAlignment="Center" VerticalContentAlignment="Center" FontSize="16" FontWeight="Bold"/>
                    <TextBox x:Name="txtJ2_5" Grid.Row="1" Grid.Column="5" Margin="3" TextAlignment="Center" VerticalContentAlignment="Center" FontSize="16" FontWeight="Bold"/>
                    <TextBox x:Name="txtJ2_6" Grid.Row="1" Grid.Column="6" Margin="3" TextAlignment="Center" VerticalContentAlignment="Center" FontSize="16" FontWeight="Bold"/>

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Jugada 3:" Foreground="White" VerticalAlignment="Center" FontWeight="Bold"/>
                    <TextBox x:Name="txtJ3_1" Grid.Row="2" Grid.Column="1" Margin="3" TextAlignment="Center" VerticalContentAlignment="Center" FontSize="16" FontWeight="Bold"/>
                    <TextBox x:Name="txtJ3_2" Grid.Row="2" Grid.Column="2" Margin="3" TextAlignment="Center" VerticalContentAlignment="Center" FontSize="16" FontWeight="Bold"/>
                    <TextBox x:Name="txtJ3_3" Grid.Row="2" Grid.Column="3" Margin="3" TextAlignment="Center" VerticalContentAlignment="Center" FontSize="16" FontWeight="Bold"/>
                    <TextBox x:Name="txtJ3_4" Grid.Row="2" Grid.Column="4" Margin="3" TextAlignment="Center" VerticalContentAlignment="Center" FontSize="16" FontWeight="Bold"/>
                    <TextBox x:Name="txtJ3_5" Grid.Row="2" Grid.Column="5" Margin="3" TextAlignment="Center" VerticalContentAlignment="Center" FontSize="16" FontWeight="Bold"/>
                    <TextBox x:Name="txtJ3_6" Grid.Row="2" Grid.Column="6" Margin="3" TextAlignment="Center" VerticalContentAlignment="Center" FontSize="16" FontWeight="Bold"/>
                </Grid>
            </Border>

            <Button x:Name="btnSortear" Content="¡EMPEZAR JUGADA!" Background="#FFC000" Foreground="Black" 
                    Height="40" FontSize="14" FontWeight="Bold" Click="btnSortear_Click" Cursor="Hand"/>
        </StackPanel>

        <Border Grid.Column="1" Background="#FFE600" BorderBrush="#D1BC00" BorderThickness="2" CornerRadius="10" Padding="20">
            <StackPanel VerticalAlignment="Center">

                <TextBlock Text="TINKA" Foreground="#008000" FontSize="36" FontWeight="Black" FontStyle="Italic" HorizontalAlignment="Center" Margin="0,0,0,5"/>
                <TextBlock Text="JUGADA GANADORA SÍ O SÍ" Foreground="#008000" FontSize="16" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,20"/>

                <Border Background="White" CornerRadius="15" Padding="15" Margin="0,0,0,25">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock x:Name="lblT1" Text="-" FontSize="24" FontWeight="Black" Margin="8,0" Foreground="Black"/>
                        <TextBlock x:Name="lblT2" Text="-" FontSize="24" FontWeight="Black" Margin="8,0" Foreground="Black"/>
                        <TextBlock x:Name="lblT3" Text="-" FontSize="24" FontWeight="Black" Margin="8,0" Foreground="Black"/>
                        <TextBlock x:Name="lblT4" Text="-" FontSize="24" FontWeight="Black" Margin="8,0" Foreground="Black"/>
                        <TextBlock x:Name="lblT5" Text="-" FontSize="24" FontWeight="Black" Margin="8,0" Foreground="Black"/>
                        <TextBlock x:Name="lblT6" Text="-" FontSize="24" FontWeight="Black" Margin="8,0" Foreground="Black"/>
                    </StackPanel>
                </Border>

                <Border BorderBrush="#008000" BorderThickness="0,0,0,1" Margin="0,5" Padding="0,0,0,2">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="NOMBRE: " Foreground="#008000" FontWeight="Bold" FontSize="11"/>
                        <TextBlock x:Name="lblTicketNombre" Text="---" Foreground="#008000" FontSize="11" FontWeight="Bold" Margin="5,0,0,0"/>
                    </StackPanel>
                </Border>

                <Border BorderBrush="#008000" BorderThickness="0,0,0,1" Margin="0,5" Padding="0,0,0,2">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="DIRECCIÓN: " Foreground="#008000" FontWeight="Bold" FontSize="11"/>
                        <TextBlock x:Name="lblTicketDireccion" Text="---" Foreground="#008000" FontSize="11" FontWeight="Bold" Margin="5,0,0,0"/>
                    </StackPanel>
                </Border>

                <Border BorderBrush="#008000" BorderThickness="0,0,0,1" Margin="0,5,0,20" Padding="0,0,0,2">
                    <Grid>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                            <TextBlock Text="TERMINAL: 0710810" Foreground="#008000" FontWeight="Bold" FontSize="11"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <TextBlock Text="FECHA: " Foreground="#008000" FontWeight="Bold" FontSize="11"/>
                            <TextBlock x:Name="lblTicketFecha" Text="---" Foreground="#008000" FontWeight="Bold" FontSize="11" Margin="5,0,0,0"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <TextBlock x:Name="lblMensajePremio" Text="¡Mucha Suerte!" Foreground="Red" FontSize="14" FontWeight="Bold" HorizontalAlignment="Center"/>

            </StackPanel>
        </Border>

    </Grid>
</Window>