<Window x:Class="Juego21.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Juego21" Height="600" Width="1100">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Botón Superior -->
        <Button x:Name="btnNuevoJuego" 
                Content="Nuevo Juego" 
                Width="120" 
                Height="30" 
                Margin="0,0,0,10"
                Click="btnNuevoJuego_Click"/>

        <!-- Área de los Jugadores -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1*"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>

            <!-- PANEL JUGADOR 1 -->
            <Border Grid.Column="0" Background="#2E7D32" Margin="5" CornerRadius="5">
                <Grid Margin="15">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Puntos J1 -->
                    <StackPanel Orientation="Horizontal" Grid.Row="0">
                        <TextBlock Text="Jugador 1Puntos: " Foreground="White" FontWeight="Bold" FontSize="18"/>
                        <TextBlock x:Name="lblPuntosJ1" Text="0" Foreground="Yellow" FontWeight="Bold" FontSize="18"/>
                    </StackPanel>

                    <!-- Cartas J1 -->
                    <WrapPanel x:Name="pnlCartasJ1" Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Left"/>

                    <!-- Controles J1 -->
                    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center">
                        <Button x:Name="btnPedirJ1" Content="Pedir Carta" Width="90" Height="30" Margin="0,0,10,0" Click="btnPedirJ1_Click" IsEnabled="False"/>
                        <Button x:Name="btnPlantarJ1" Content="Plantarse" Width="90" Height="30" Click="btnPlantarJ1_Click" IsEnabled="False"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- PANEL JUGADOR 2 -->
            <Border Grid.Column="1" Background="#2E7D32" Margin="5" CornerRadius="5">
                <Grid Margin="15">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Puntos J2 -->
                    <StackPanel Orientation="Horizontal" Grid.Row="0">
                        <TextBlock Text="Jugador 2Puntos: " Foreground="White" FontWeight="Bold" FontSize="18"/>
                        <TextBlock x:Name="lblPuntosJ2" Text="0" Foreground="Yellow" FontWeight="Bold" FontSize="18"/>
                    </StackPanel>

                    <!-- Cartas J2 -->
                    <WrapPanel x:Name="pnlCartasJ2" Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Left"/>

                    <!-- Controles J2 -->
                    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center">
                        <Button x:Name="btnPedirJ2" Content="Pedir Carta" Width="90" Height="30" Margin="0,0,10,0" Click="btnPedirJ2_Click" IsEnabled="False"/>
                        <Button x:Name="btnPlantarJ2" Content="Plantarse" Width="90" Height="30" Click="btnPlantarJ2_Click" IsEnabled="False"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <!-- Barra Inferior de Resultados -->
        <Border x:Name="brdResultado" Grid.Row="2" Background="#FFF2A8" Margin="5,10,5,0" Padding="10" BorderBrush="#D4C06A" BorderThickness="1" CornerRadius="3" Visibility="Collapsed">
            <TextBlock x:Name="txtResultado" 
                       Text="¡GANADOR JUGADOR 2! Obtuvo 20 puntos frente a 18 del J1." 
                       HorizontalAlignment="Center" 
                       FontWeight="Bold" 
                       FontSize="16"/>
        </Border>
    </Grid>
</Window>